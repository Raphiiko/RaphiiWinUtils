{
  "name": "raphii-win-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "node --watch src/main.ts run",
    "start": "node src/main.ts run",
    "test": "node --test \"src/**/*.test.ts\"",
    "clean:dist": "node scripts/cleanDist.ts",
    "build": "node scripts/stageRuntime.ts",
    "build:helper:audio": "dotnet publish ./helpers/AudioEndpointWatcher/AudioEndpointWatcher.csproj -c Release -r win-x64 --self-contained false -o ./dist/helpers/AudioEndpointWatcher",
    "build:helper:clipboard": "dotnet publish ./helpers/ClipboardWatcher/ClipboardWatcher.csproj -c Release -r win-x64 --self-contained false -o ./dist/helpers/ClipboardWatcher",
    "build:notification-assets": "node scripts/copyNotificationAssets.ts",
    "build:helper": "npm run build:helper:audio && npm run build:helper:clipboard && npm run build:notification-assets",
    "build:all": "npm run clean:dist && npm run build && npm run build:helper",
    "install:local": "node src/main.ts install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/node": "^1.4.5",
    "elysia": "^1.4.28",
    "mqtt": "^5.15.2",
    "node-notifier": "^10.0.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  }
}
