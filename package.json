{
  "name": "raphii-win-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "start": "bun run src/main.ts",
    "build": "bun build --compile --target=bun-windows-x64 ./src/main.ts --outfile ./dist/RaphiiWinUtils.exe",
    "build:helper": "dotnet publish ./helpers/AudioEndpointWatcher/AudioEndpointWatcher.csproj -c Release -r win-x64 --self-contained false -o ./dist/helpers/AudioEndpointWatcher",
    "build:all": "bun run build && bun run build:helper",
    "install:local": "bun run src/main.ts install",
    "check": "bunx tsc --noEmit"
  },
  "dependencies": {
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
