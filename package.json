{
  "name": "raphii-win-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "start": "bun run src/main.ts",
    "clean:dist": "bun run scripts/cleanDist.ts",
    "build": "bun build --compile --target=bun-windows-x64 ./src/main.ts --outfile ./dist/RaphiiWinUtils.exe && bun run stamp:exe",
    "stamp:exe": "bun run scripts/stampExe.ts",
    "build:helper:audio": "dotnet publish ./helpers/AudioEndpointWatcher/AudioEndpointWatcher.csproj -c Release -r win-x64 --self-contained false -o ./dist/helpers/AudioEndpointWatcher",
    "build:helper:clipboard": "dotnet publish ./helpers/ClipboardWatcher/ClipboardWatcher.csproj -c Release -r win-x64 --self-contained false -o ./dist/helpers/ClipboardWatcher",
    "build:notification-assets": "bun run scripts/copyNotificationAssets.ts",
    "build:helper": "bun run build:helper:audio && bun run build:helper:clipboard && bun run build:notification-assets",
    "build:all": "bun run clean:dist && bun run build && bun run build:helper",
    "install:local": "bun run src/main.ts install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "bunx tsc --noEmit"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "node-notifier": "^10.0.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "rcedit": "^5.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  }
}
